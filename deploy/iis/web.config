<?xml version="1.0" encoding="utf-8"?>
<!--
  acme-adcs-ra on IIS via HttpPlatformHandler.

  Adapted from cert-watch's deploy/iis/web.config (same FastAPI/uvicorn-on-Windows
  model, same VM). IIS launches and supervises uvicorn as a child of the
  application pool and proxies every request to it over a loopback port it
  chooses ($HTTP_PLATFORM_PORT). The Microsoft-signed HttpPlatformHandler module
  is the only IIS prerequisite.

  THE KEY DIFFERENCE FROM cert-watch: the application pool runs AS THE gMSA
  (set by scripts\install-windows.ps1 -GmsaAccount), so the uvicorn worker's
  ambient identity is the gMSA — that ambient Kerberos identity is exactly what
  authenticates to /certsrv/ (Negotiate/SSPI, passwordless). No stored secret.

  Place this file in the IIS site's physical path (e.g. C:\inetpub\acme-adcs-ra).
  The application code lives in the virtualenv created by the installer
  (default C:\ProgramData\acme-adcs-ra\venv).

  SECRETS (EAB MAC keys, SIEM HEC token) are NOT in this file — they live in the
  locked-down env file pointed to by ACME_RA_DOTENV, readable only by the gMSA +
  Administrators. This config carries only non-secret operator settings.
-->
<configuration>
  <system.webServer>
    <handlers>
      <!-- Hand every request to the Python (uvicorn) process. -->
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <!-- The RA reads its config from ACME_RA_* env vars (not argv), and binds to
         127.0.0.1:$HTTP_PLATFORM_PORT automatically (it honours HTTP_PLATFORM_PORT
         when ACME_RA_BIND_PORT is unset). So no arguments are needed here. -->
    <httpPlatform processPath="C:\ProgramData\acme-adcs-ra\venv\Scripts\python.exe"
                  arguments="-m acme_adcs_ra"
                  stdoutLogEnabled="true"
                  stdoutLogFile="C:\ProgramData\acme-adcs-ra\logs\stdout"
                  startupTimeLimit="60"
                  startupRetryCount="3"
                  requestTimeout="00:04:00">
      <environmentVariables>
        <!-- Bind to loopback; IIS terminates TLS and reverse-proxies here. -->
        <environmentVariable name="ACME_RA_BIND_HOST" value="127.0.0.1" />
        <!-- IIS terminates TLS: trust the forwarded scheme/host so the JWS
             full-URL binding (threat-model §4.D) validates instead of rejecting
             every legitimate request as a URL mismatch. -->
        <environmentVariable name="ACME_RA_TRUST_PROXY" value="true" />
        <environmentVariable name="ACME_RA_FORWARDED_ALLOW_IPS" value="127.0.0.1" />

        <!-- PUBLIC ACME URL clients use and the server signs into directory/JWS
             URLs. MUST be the public https hostname, NOT the loopback bind. -->
        <environmentVariable name="ACME_RA_BASE_URL" value="https://acme-ra.WORK-DOMAIN.local/" />

        <!-- ADCS enrollment target (Mode A: /certsrv/ on the issuing CA). -->
        <environmentVariable name="ACME_RA_ADCS_HOST" value="CA01.WORK-DOMAIN.local" />
        <environmentVariable name="ACME_RA_ADCS_TEMPLATE" value="ACME-ServerAuth" />
        <environmentVariable name="ACME_RA_ADCS_CA_NAME" value="CONTOSO-CA01-CA" />
        <!-- PEM bundle to verify the CA's /certsrv/ TLS cert (private CA). Unset
             => the host's OS trust store. -->
        <!-- <environmentVariable name="ACME_RA_ADCS_CA_BUNDLE" value="C:\ProgramData\acme-adcs-ra\ca-chain.pem" /> -->

        <!-- Authoritative audit store + SIEM jsonl (next to the DB by default). -->
        <environmentVariable name="ACME_RA_DB_PATH" value="C:\ProgramData\acme-adcs-ra\acme_ra.db" />

        <!-- Secret-bearing env file (EAB MAC keys, HEC token) in the locked data
             dir — keeps secrets out of this checked-in-adjacent config. -->
        <environmentVariable name="ACME_RA_DOTENV" value="C:\ProgramData\acme-adcs-ra\acme-ra.env" />
      </environmentVariables>
    </httpPlatform>

    <!-- Don't advertise the IIS/Python stack. -->
    <security>
      <requestFiltering removeServerHeader="true" />
      <!-- RECOMMENDED (threat-model pilot condition): restrict the ACME endpoint
           to the authorized client(s). Requires the "IP and Domain Restrictions"
           role service. Set allowUnlisted="false" and add the client IP(s):
      <ipSecurity allowUnlisted="false">
        <add ipAddress="10.0.0.50" allowed="true" />
      </ipSecurity>
      -->
    </security>

    <!-- HSTS when IIS is the TLS terminator. -->
    <httpProtocol>
      <customHeaders>
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
